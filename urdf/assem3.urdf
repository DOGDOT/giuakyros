<?xml version="1.0"?>
<robot name="assem3">

  <link name="base_footprint"/>
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="-0.78773 -1.1702 -1.22185" rpy="-1.5708 0 0"/>
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="0.67067 -1.3074 1.2216" rpy="0 0 0" />
      <mass value="5.2" />
      <inertia ixx="0.0049485" ixy="0.0" ixz="0.0" iyy="0.013487" iyz="0.0" izz="0.011268" />
    </inertial>
    <visual>
      <geometry><mesh filename="package://assem3/meshes/base_link.STL" /></geometry>
      <material name=""><color rgba="1 1 1 1" /></material>
    </visual>
    <collision>
      <origin xyz="0.67 -1.30 1.25" rpy="0 0 0" />
      <geometry><box size="0.2 0.2 0.1"/></geometry>
    </collision>
  </link>
  <gazebo reference="base_link"><material>Gazebo/Orange</material></gazebo>

  <link name="banhtrai_link">
    <inertial>
      <mass value="2.5" />
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
    </inertial>
    <visual><geometry><mesh filename="package://assem3/meshes/banhtrai_link.STL" /></geometry></visual>
    <collision><geometry><sphere radius="0.055"/></geometry></collision>
  </link>
  <joint name="banhtrai_joint" type="continuous">
    <origin xyz="0.78773 -1.2452 1.3549" rpy="0 0 -3.1416" />
    <parent link="base_link" /><child link="banhtrai_link" /><axis xyz="0 0 1" />
  </joint>
  <gazebo reference="banhtrai_link">
    <material>Gazebo/Black</material>
    <mu1>200.0</mu1><mu2>200.0</mu2> </gazebo>

  <link name="banhphai_link">
    <inertial>
      <mass value="2.5" />
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
    </inertial>
    <visual><geometry><mesh filename="package://assem3/meshes/banhphai_link.STL" /></geometry></visual>
    <collision><geometry><sphere radius="0.055"/></geometry></collision>
  </link>
  <joint name="banhphai_joint" type="continuous">
    <origin xyz="0.78773 -1.2452 1.0888" rpy="-3.1416 0 0" />
    <parent link="base_link" /><child link="banhphai_link" /><axis xyz="0 0 -1" />
  </joint>
  <gazebo reference="banhphai_link">
    <material>Gazebo/Black</material>
    <mu1>200.0</mu1><mu2>200.0</mu2>
  </gazebo>

  <link name="phaitren">
    <inertial><mass value="0.05"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
    <visual><geometry><mesh filename="package://assem3/meshes/phaitren.STL"/></geometry></visual>
    <collision><geometry><mesh filename="package://assem3/meshes/phaitren.STL"/></geometry></collision>
  </link>
  <joint name="phaitren_link" type="fixed"><parent link="base_link"/><child link="phaitren"/></joint>
  <gazebo reference="phaitren"><material>Gazebo/DarkGrey</material><mu1>0.0</mu1><mu2>0.0</mu2></gazebo>

  <link name="traitren">
    <inertial><mass value="0.05"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
    <visual><geometry><mesh filename="package://assem3/meshes/traitren.STL"/></geometry></visual>
    <collision><geometry><mesh filename="package://assem3/meshes/traitren.STL"/></geometry></collision>
  </link>
  <joint name="traitren_link" type="fixed"><parent link="base_link"/><child link="traitren"/></joint>
  <gazebo reference="traitren"><material>Gazebo/DarkGrey</material><mu1>0.0</mu1><mu2>0.0</mu2></gazebo>

  <link name="traiduoi">
    <inertial><mass value="0.05"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
    <visual><geometry><mesh filename="package://assem3/meshes/traiduoi.STL"/></geometry></visual>
    <collision><geometry><mesh filename="package://assem3/meshes/traiduoi.STL"/></geometry></collision>
  </link>
  <joint name="traiduoi_link" type="fixed"><parent link="base_link"/><child link="traiduoi"/></joint>
  <gazebo reference="traiduoi"><material>Gazebo/DarkGrey</material><mu1>0.0</mu1><mu2>0.0</mu2></gazebo>

  <link name="phaiduoi">
    <inertial><mass value="0.05"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
    <visual><geometry><mesh filename="package://assem3/meshes/phaiduoi.STL"/></geometry></visual>
    <collision><geometry><mesh filename="package://assem3/meshes/phaiduoi.STL"/></geometry></collision>
  </link>
  <joint name="phaiduoi_link" type="fixed"><parent link="base_link"/><child link="phaiduoi"/></joint>
  <gazebo reference="phaiduoi"><material>Gazebo/DarkGrey</material><mu1>0.0</mu1><mu2>0.0</mu2></gazebo>

  <link name="dexoay">
    <inertial><mass value="1.637" /><inertia ixx="0.005" ixy="0.0" ixz="0.0" iyy="0.006" iyz="0.0" izz="0.007" /></inertial>
    <visual><geometry><mesh filename="package://assem3/meshes/dexoay.STL" /></geometry></visual>
  </link>
  <joint name="dexoay_joint" type="revolute">
    <origin xyz="0.67273 -1.3541 1.2215" rpy="1.5708 0 0" />
    <parent link="base_link" /><child link="dexoay" />
    <axis xyz="0 0 1" />
    <limit lower="-3.14" upper="3.14" effort="100.0" velocity="10.0" />
    <dynamics damping="0.1" friction="0.1"/>
  </joint>
  <gazebo reference="dexoay"><material>Gazebo/White</material></gazebo>

  <link name="khau1">
    <inertial><mass value="0.904" /><inertia ixx="0.003" ixy="0.0" ixz="0.0" iyy="0.003" iyz="0.0" izz="0.004" /></inertial>
    <visual><geometry><mesh filename="package://assem3/meshes/khau1.STL" /></geometry></visual>
  </link>
  <joint name="khau1_joint" type="revolute">
    <origin xyz="0 -0.0053 0.133" rpy="1.5691 1.5708 0" />
    <parent link="dexoay" /><child link="khau1" />
    <axis xyz="0 0 1" />
    <limit lower="-1.57" upper="1.57" effort="100.0" velocity="10.0" />
    <dynamics damping="0.1" friction="0.1"/>
  </joint>
  <gazebo reference="khau1"><material>Gazebo/White</material></gazebo>

  <link name="lidar1">
    <inertial><mass value="0.1" /><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001" /></inertial>
    <visual><geometry><mesh filename="package://assem3/meshes/lidar1.STL" /></geometry></visual>
  </link>
  <joint name="lidar1_joint" type="fixed"><origin xyz="0.81921 -1.3394 1.2215" rpy="1.5708 0 0" /><parent link="base_link" /><child link="lidar1" /></joint>
  <gazebo reference="lidar1"><material>Gazebo/DarkGrey</material></gazebo>

  <link name="lidar2">
    <inertial><mass value="0.1" /><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001" /></inertial>
    <visual><geometry><mesh filename="package://assem3/meshes/lidar2.STL" /></geometry></visual>
  </link>
  <joint name="lidar2_joint" type="fixed"><origin xyz="0.51624 -1.3394 1.2215" rpy="-1.5708 0 -3.1416" /><parent link="base_link" /><child link="lidar2" /></joint>
  <gazebo reference="lidar2"><material>Gazebo/DarkGrey</material></gazebo>

  <link name="camera">
    <inertial><mass value="0.05" /><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001" /></inertial>
    <visual><geometry><mesh filename="package://assem3/meshes/camera.STL" /></geometry></visual>
  </link>
  <joint name="camera_joint" type="fixed"><origin xyz="0.1018 0.00017264 0.039288" rpy="-1.5708 0 -1.5691" /><parent link="dexoay" /><child link="camera" /></joint>
  <gazebo reference="camera"><material>Gazebo/Blue</material></gazebo>

  <gazebo>
    <plugin name="gazebo_ros_diff_drive" filename="libgazebo_ros_diff_drive.so">
      <update_rate>50.0</update_rate>
      <left_joint>banhtrai_joint</left_joint>
      <right_joint>banhphai_joint</right_joint>
      <wheel_separation>0.266</wheel_separation>
      <wheel_diameter>0.15</wheel_diameter>
      
      <command_topic>cmd_vel</command_topic>
      
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
    </plugin>
    
    <plugin name="gazebo_ros_joint_state_publisher" filename="libgazebo_ros_joint_state_publisher.so">
      <update_rate>50</update_rate>
      <joint_name>banhtrai_joint</joint_name>
      <joint_name>banhphai_joint</joint_name>
    </plugin>
  </gazebo>
  
<ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>
    <joint name="dexoay_joint">
      <command_interface name="position">
        <param name="min">-3.14</param>
        <param name="max">3.14</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="khau1_joint">
      <command_interface name="position">
        <param name="min">-1.57</param>
        <param name="max">1.57</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <robot_param>robot_description</robot_param>
      <robot_param_node>robot_state_publisher</robot_param_node>
      <parameters>ABSOLUTE_PATH_TO_YAML</parameters>
    </plugin>
  </gazebo>

  <gazebo reference="camera"><material>Gazebo/Blue</material></gazebo>

  <link name="camera_lens"/>
  <joint name="camera_lens_joint" type="fixed">
    <origin xyz="0.1018 0.00017 0.039" rpy="0 0 0" />
    <parent link="dexoay" />
    <child link="camera_lens" />
  </joint>

  <link name="camera_optical"/>
  <joint name="camera_optical_joint" type="fixed">
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708" />
    <parent link="camera_lens" />
    <child link="camera_optical" />
  </joint>

  <gazebo reference="camera_lens">
    <sensor type="camera" name="camera_sensor">
      <update_rate>30.0</update_rate>
      <visualize>true</visualize>
      <camera name="head">
        <horizontal_fov>1.396</horizontal_fov>
        <image><width>640</width><height>480</height><format>R8G8B8</format></image>
        <clip><near>0.02</near><far>300</far></clip>
      </camera>
      <plugin name="gazebo_ros_camera" filename="libgazebo_ros_camera.so">
        <camera_name>camera</camera_name>
        <frame_name>camera_optical</frame_name> 
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="lidar1">
    <material>Gazebo/DarkGrey</material>
    <sensor type="ray" name="lidar1_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize> <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range><min>0.15</min><max>12.0</max><resolution>0.01</resolution></range>
      </ray>
      <plugin name="gazebo_ros_lidar1" filename="libgazebo_ros_ray_sensor.so">
        <ros><remapping>~/out:=scan_1</remapping></ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar1</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="lidar2">
    <material>Gazebo/DarkGrey</material>
    <sensor type="ray" name="lidar2_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range><min>0.15</min><max>12.0</max><resolution>0.01</resolution></range>
      </ray>
      <plugin name="gazebo_ros_lidar2" filename="libgazebo_ros_ray_sensor.so">
        <ros><remapping>~/out:=scan_2</remapping></ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar2</frame_name>
      </plugin>
    </sensor>
  </gazebo>

</robot>